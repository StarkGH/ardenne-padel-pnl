{
  "name": "ardenne-padel-pnl",
  "version": "1.0.0",
  "type": "module",
  "description": "Pipeline financier Ardenne Padel — parsers fournisseurs + PostgreSQL",
  "scripts": {
    "import": "node src/importers/import-invoices.js",
    "import:dry": "node src/importers/import-invoices.js --dry-run",
    "import:colruyt": "node src/importers/import-invoices.js --supplier=colruyt",
    "import:colruyt:dry": "node src/importers/import-invoices.js --dry-run --supplier=colruyt",
    "import:comarche": "node src/importers/import-invoices.js --supplier=comarche",
    "import:comarche:dry": "node src/importers/import-invoices.js --dry-run --supplier=comarche",
    "import:conte": "node src/importers/import-invoices.js --supplier=conte_salm",
    "import:conte:dry": "node src/importers/import-invoices.js --dry-run --supplier=conte_salm",
    "db:migrate": "node db.js",
    "db:schema": "node -e \"import('./db.js').then(m => m.migrate())\"",
    "test:pdf": "node src/parsers/detrembleur.js",
    "import:coda": "node src/adapters/belfius-coda/importer.js",
    "import:coda:dry": "node src/adapters/belfius-coda/importer.js --dry-run",
    "import:registers": "node src/adapters/nextore-registers/importer.js",
    "import:registers:dry": "node src/adapters/nextore-registers/importer.js --dry-run",
    "export:consolidation": "node src/exporters/export-consolidation-t4.js",
    "import:doinsport": "node src/adapters/doinsport/importer.js",
    "import:doinsport:dry": "node src/adapters/doinsport/importer.js --dry-run",
    "export:reconciliation": "node src/exporters/export-reconciliation-terrain.js",
    "export:detrembleur:matrices": "node src/exporters/export-detrembleur-product-matrices.js",
    "export:detrembleur:commandes": "node src/exporters/export-detrembleur-commandes.xlsx.js",
    "bank:connect": "node src/adapters/enable-banking/connect.js",
    "bank:connect:bnp": "node src/adapters/enable-banking/connect.js --bank=bnp",
    "bank:connect:test": "node src/adapters/enable-banking/connect.js --bank=bbva",
    "export:nextore:matrices": "node src/exporters/export-nextore-register-matrices.js",
    "ui:product-mappings": "node src/apps/product-mappings-ui.js",
    "verify:ui:mappings": "node src/apps/verify-product-mappings-ui.js",
    "verify:others": "node src/apps/verify-other-suppliers.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "jsonwebtoken": "^9.0.3",
    "luxon": "^3.5.0",
    "node-fetch": "^3.3.2",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.3"
  }
}
